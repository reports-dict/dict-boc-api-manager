{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"]
        },
        "types": ["vite/client"],
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": ["resources/js/**/*"],
    "exclude": ["node_modules", "vendor"]
}
